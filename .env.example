# Solo servidor (Vercel: sin prefijo VITE; no se incluye en el bundle del navegador)
ANTHROPIC_API_KEY=sk-ant-...

# Cliente (coach, publicar semana en Supabase)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Opcional: código de acceso vista ?coach (prioridad sobre localStorage del programador). Si no se define, se usa lo guardado en la app principal o EVO19.
# VITE_COACH_ACCESS_CODE=EVO19

# ── Panel «Contenido Coach» (solo servidor en Vercel; NO uses prefijo VITE_) ──
# COACH_GUIDE_ADMIN_SECRET
#   → Cualquier contraseña larga que TÚ inventes (ej. 32+ caracteres aleatorios).
#   → Es la clave que escribes en el panel al guardar. NO es el código de los coaches (EVO19).
#
# SUPABASE_SERVICE_ROLE_KEY
#   → Supabase Dashboard → tu proyecto → Project Settings (engranaje) → API
#   → Bloque "Project API keys" → clave "service_role" (Secret). Copiar entera.
#   → Nunca la pongas en VITE_ ni en el front: bypassa RLS.
#
# SUPABASE_URL (opcional en Vercel)
#   → Mismo valor que VITE_SUPABASE_URL (https://TU_REF.supabase.co).
#   → Si solo tienes VITE_SUPABASE_URL en Vercel, la API ya la usa como fallback.
#
# COACH_GUIDE_ADMIN_SECRET=pon_aqui_tu_secreto_largo
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_URL=https://xxxx.supabase.co

# Opcional: modelo Claude programación / agente (por defecto claude-sonnet-4-20250514)
# VITE_CLAUDE_MODEL=claude-sonnet-4-20250514
# Opcional: modelo chat soporte coach ?coach (por defecto claude-haiku-4-5-20251001)
# VITE_CLAUDE_SUPPORT_MODEL=claude-haiku-4-5-20251001
